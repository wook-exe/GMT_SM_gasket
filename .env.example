# 추론 우선순위: VITE_API_URL → VITE_GEMINI_API_KEY → mock

# 1순위: Colab FastAPI + ngrok 터널 주소 (실제 PatchCore 모델). 비워두면 다음 단계로 fallback.
VITE_API_URL=

# 2순위: Google Gemini Vision API 키 (무료 티어)
#   - 발급: https://aistudio.google.com/app/apikey
#   - 무료 한도: 분당 15회 / 일 1,500회 (gemini-2.0-flash 기준)
#   - 결제수단 등록 불필요
#   - 챗봇에서도 같은 키 사용
