# (옵션) Claude Vision API 키 — 유료. Gemini 사용 시 비워둬도 됨.
VITE_ANTHROPIC_API_KEY=

# ─────────────────────────────────────────────────────────────
# Firebase Firestore (선택) — 검사 이력을 클라우드에 보관, 기기/브라우저 간 공유
# 미설정 시 localStorage 만 사용. 6개 모두 채워야 활성화됨.
#
# 발급 절차:
#   1) https://console.firebase.google.com 에서 새 프로젝트 생성
#   2) 좌측 메뉴 "Firestore Database" → "데이터베이스 만들기" → 위치 선택 (asia-northeast3 권장)
#   3) 보안 규칙은 데모용으로 아래처럼 설정 (PoC 한정, 외부 공개 시 반드시 강화):
#        rules_version = '2';
#        service cloud.firestore {
#          match /databases/{database}/documents {
#            match /inspections/{docId} {
#              allow read, write: if true;
#            }
#          }
#        }
#   4) 프로젝트 설정 → 일반 → "내 앱" → 웹 앱(</>) 추가 → 닉네임 입력 → 등록
#   5) 표시되는 firebaseConfig 의 6개 값을 아래에 옮겨 적기
# ─────────────────────────────────────────────────────────────
VITE_FIREBASE_API_KEY=AIzaSyBoHcU7OfK5ngPF6xwGAow1uvi1j30nVZM
VITE_FIREBASE_AUTH_DOMAIN=gmt-ab1e0.firebaseapp.com
